# ============================================================
# PETP .gitignore
# ============================================================

# IDE
.idea/
.vscode/
.claude/

# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
*.egg

# Distribution / packaging
.Python
build/
dist/
*.manifest

# PyInstaller generated spec (rebuilt from PETP_build.spec)
PETP.spec
PETP_background.spec
PETP_debug.spec

# Runtime output
download/*
!download/.gitkeep
log/*
!log/.gitkeep

# Environments
.env
.venv
env/
venv/

# Testing / coverage
htmlcov/
.coverage
.cache

# Logs
*.log

# mypy
.mypy_cache/
/CLAUDE.md
/webapp/CLAUDE.md
/AGENT.md
