POST {{baseURL}}/petp/exec
Content-Type: application/json
Content-Length: 157

{
    "action": "execution",
    "params":{
        "execution":"test_mcp_input_output",
        "fromHTTPservice":true,
        "given":"DIDIDADIDA"
    }
}

